    "scenarios = {\n",
    "    '2G Edge (100 kbps)':   100,\n",
    "    '3G (1 Mbps)':         1000,\n",
    "    '4G (5 Mbps)':         5000,\n",
    "    'WiFi (10 Mbps)':     10000,\n",
